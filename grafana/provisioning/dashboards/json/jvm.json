{
  "uid": "pgs-jvm",
  "title": "Payment Gateway — JVM",
  "tags": ["payment-gateway", "jvm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Heap memory",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "sum(jvm_memory_used_bytes{job=\"payment-gateway-service\", area=\"heap\"})", "legendFormat": "used" },
        { "refId": "B", "expr": "sum(jvm_memory_committed_bytes{job=\"payment-gateway-service\", area=\"heap\"})", "legendFormat": "committed" },
        { "refId": "C", "expr": "sum(jvm_memory_max_bytes{job=\"payment-gateway-service\", area=\"heap\"} > 0)", "legendFormat": "max" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Heap by pool",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum by (id) (jvm_memory_used_bytes{job=\"payment-gateway-service\", area=\"heap\"})", "legendFormat": "{{id}}" } ],
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "GC pause (rate of time spent)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "sum by (cause) (rate(jvm_gc_pause_seconds_sum{job=\"payment-gateway-service\"}[$__rate_interval]))", "legendFormat": "{{cause}}" } ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Threads",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "jvm_threads_live_threads{job=\"payment-gateway-service\"}", "legendFormat": "live" },
        { "refId": "B", "expr": "jvm_threads_daemon_threads{job=\"payment-gateway-service\"}", "legendFormat": "daemon" },
        { "refId": "C", "expr": "jvm_threads_peak_threads{job=\"payment-gateway-service\"}", "legendFormat": "peak" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0 } } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU usage",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "refId": "A", "expr": "process_cpu_usage{job=\"payment-gateway-service\"}", "legendFormat": "process" },
        { "refId": "B", "expr": "system_cpu_usage{job=\"payment-gateway-service\"}", "legendFormat": "system" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } } }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "process_uptime_seconds{job=\"payment-gateway-service\"}" } ],
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Loaded classes",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [ { "refId": "A", "expr": "jvm_classes_loaded_classes{job=\"payment-gateway-service\"}" } ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } }
    }
  ]
}
